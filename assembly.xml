<assembly xmlns="http://maven.apache.org/ASSEMBLY/2.0.0"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://maven.apache.org/ASSEMBLY/2.0.0 http://maven.apache.org/xsd/assembly-2.0.0.xsd">
    <id>conf</id>
    <includeBaseDirectory>false</includeBaseDirectory>

    <formats>
        <format>tar.gz</format>
    </formats>
    <fileSets>
        <fileSet>
            <directory>${project.basedir}/.output</directory>
            <outputDirectory>/.output</outputDirectory>
        </fileSet>
        <fileSet>
            <directory>${project.basedir}</directory>
            <outputDirectory>/</outputDirectory>
            <excludes>
                <exclude>assembly.xml</exclude>
                <exclude>pom.xml</exclude>
                <exclude>trivy.json</exclude>
                <exclude>.output/**</exclude>
                <exclude>node_modules/**</exclude>
                <exclude>node/**</exclude>
                <exclude>target/**</exclude>
                <exclude>.nuxt/**</exclude>
                <exclude>.git/**</exclude>
                <exclude>stubs/**</exclude>
            </excludes>
        </fileSet>
    </fileSets>
</assembly>
